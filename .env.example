# Database — SQLite file path
DATABASE_URL="file:./dev.db"

# NextAuth session signing secret (generate with: openssl rand -base64 32)
AUTH_SECRET="change-me-to-a-random-secret"

# Application base URL
APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Google Gemini API for AI receipt parsing
GOOGLE_AI_API_KEY=""
GOOGLE_AI_MODEL="gemini-2.5-flash"

# Local file storage directory for uploaded receipts
LOCAL_STORAGE_DIR="data/uploads"

# --- Cloud deployment (optional — leave unset for local dev) ---

# Turso database (replaces local SQLite when deployed)
# TURSO_DATABASE_URL="libsql://your-db-name-your-org.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# Vercel Blob storage (replaces local filesystem when deployed)
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
