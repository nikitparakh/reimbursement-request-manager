# ---------------------------------------------------------------------------
# Local development (.env). Production runs on Cloudflare Workers where DB and
# storage come from bindings (D1 / R2) and secrets come from `wrangler secret`.
# For local Cloudflare dev (`wrangler dev` / `opennextjs-cloudflare preview`),
# put Clerk/Gemini values in `.dev.vars` instead (see .dev.vars).
# ---------------------------------------------------------------------------

# Local SQLite file used by the seed script and tests
DATABASE_URL="file:./local.db"

# Application base URL
APP_URL="http://localhost:3000"

# Clerk authentication (https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# PEM public key for networkless JWT verification on Workers
CLERK_JWT_KEY=""
# Point Clerk at the app's own sign-in/up routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/"

# Google Gemini API for AI receipt parsing
GOOGLE_AI_API_KEY=""
GOOGLE_AI_MODEL="gemini-2.5-flash"

# Local file storage directory for uploaded receipts (dev/test fallback;
# production uses the R2 RECEIPTS_BUCKET binding)
LOCAL_STORAGE_DIR="data/uploads"

# --- Seeding a remote Turso/libSQL database (optional) ---
# The standalone seed script (npm run db:seed) targets these when set.
# TURSO_DATABASE_URL="libsql://your-db.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"
