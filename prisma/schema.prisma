// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  USER
  SUPER_ADMIN
}

enum ScopedRole {
  SCHOOL_ADMIN
  PROGRAM_ADMIN
  COACH
  PARENT_MENTOR
}

enum TeamMembershipRole {
  PARENT_MENTOR
  COACH
}

enum ProgramCode {
  LEGACY
  FLL
  FTC
  FRC
}

enum FllDivision {
  DISCOVER
  EXPLORE
  CHALLENGE
}

enum TeamRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestStatus {
  DRAFT
  SUBMITTED
  COACH_APPROVED
  COACH_REJECTED
  ADMIN_APPROVED
  ADMIN_REJECTED
  PAID
}

enum ParseStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

enum DocumentType {
  RECEIPT
  INVOICE
  W9
  CHECK_REQUEST_FORM
  OTHER
}

enum DecisionAction {
  APPROVE
  REJECT
  REOPEN
  MARK_PAID
  SUBMIT
}

model User {
  id              String             @id @default(cuid())
  name            String?
  email           String             @unique
  passwordHash    String?
  emailVerified   DateTime?
  image           String?
  role            GlobalRole         @default(USER)
  onboardingDone  Boolean            @default(false)
  mailingAddressLine1 String?
  mailingAddressLine2 String?
  mailingCity     String?
  mailingState    String?
  mailingPostalCode String?
  zelleType       String?
  zelleValue      String?
  policyAcceptedAt DateTime?
  policyVersion   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  accounts        Account[]
  sessions        Session[]
  scopedRoles     UserScopeRole[]
  memberships     TeamMembership[]
  createdRequests ReimbursementRequest[] @relation("RequestCreatedBy")
  coachedRequests ReimbursementRequest[] @relation("RequestCoach")
  teamRequests    TeamRegistrationRequest[] @relation("TeamRequestCreatedBy")
  reviewedTeamRequests TeamRegistrationRequest[] @relation("TeamRequestReviewedBy")
  approvals       ApprovalAction[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  excludedLineItems ReceiptLineItem[] @relation("LineItemExcludedBy")
  lineItemComments  LineItemComment[]
}

model District {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  schools   School[]
  teamRegistrationRequests TeamRegistrationRequest[]
  scopedRoles UserScopeRole[]
}

model School {
  id         String   @id @default(cuid())
  districtId String
  name       String
  slug       String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)
  teams      Team[]
  teamRegistrationRequests TeamRegistrationRequest[]
  scopedRoles UserScopeRole[]

  @@unique([districtId, slug])
  @@unique([districtId, name])
}

model Program {
  id              String      @id @default(cuid())
  code            ProgramCode @unique
  name            String
  description     String?
  gradeRangeLabel String?
  ageRangeLabel   String?
  active          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  teams           Team[]
  teamRegistrationRequests TeamRegistrationRequest[]
  scopedRoles     UserScopeRole[]
}

model UserScopeRole {
  id         String     @id @default(cuid())
  userId      String
  role        ScopedRole
  districtId  String?
  schoolId    String?
  programId   String?
  teamId      String?
  scopeKey    String
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  district    District?  @relation(fields: [districtId], references: [id], onDelete: Cascade)
  school      School?    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  program      Program?   @relation(fields: [programId], references: [id], onDelete: Cascade)
  team        Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, role, scopeKey])
  @@index([userId, role])
  @@index([districtId, role])
  @@index([schoolId, role])
  @@index([programId, role])
  @@index([teamId, role])
}

model Team {
  id                     String                    @id @default(cuid())
  schoolId               String
  programId              String
  name                   String
  shortCode              String?
  glAccount              String?
  fllDivision            FllDivision?
  active                 Boolean                   @default(true)
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  school                 School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  program                Program                   @relation(fields: [programId], references: [id], onDelete: Restrict)
  scopedRoles            UserScopeRole[]
  memberships            TeamMembership[]
  requests               ReimbursementRequest[]
  teamRegistrationSource TeamRegistrationRequest?  @relation("ApprovedTeamSource")

  @@unique([schoolId, programId, name])
  @@unique([schoolId, shortCode])
  @@index([schoolId, programId, active])
}

model TeamMembership {
  id        String             @id @default(cuid())
  userId    String
  teamId    String
  roleInTeam TeamMembershipRole
  approved  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId, roleInTeam])
  @@index([teamId, roleInTeam])
}

model TeamRegistrationRequest {
  id            String                 @id @default(cuid())
  districtId     String
  schoolId       String
  programId      String
  teamName       String
  shortCode      String?
  glAccount      String?
  fllDivision    FllDivision?
  notes          String?
  status         TeamRegistrationStatus @default(PENDING)
  requestedById  String
  reviewedById   String?
  reviewedAt     DateTime?
  rejectionReason String?
  approvedTeamId String?                @unique
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  district       District               @relation(fields: [districtId], references: [id], onDelete: Restrict)
  school         School                 @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  program        Program                @relation(fields: [programId], references: [id], onDelete: Restrict)
  requestedBy    User                   @relation("TeamRequestCreatedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedBy     User?                  @relation("TeamRequestReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  approvedTeam   Team?                  @relation("ApprovedTeamSource", fields: [approvedTeamId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([districtId, schoolId, programId, status])
}

model ReimbursementRequest {
  id             String            @id @default(cuid())
  title          String
  description    String?
  requestedTotal Decimal
  status         RequestStatus     @default(DRAFT)
  submittedAt    DateTime?
  teamId         String
  createdById    String
  coachId        String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  team           Team              @relation(fields: [teamId], references: [id], onDelete: Restrict)
  createdBy      User              @relation("RequestCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  coach          User?             @relation("RequestCoach", fields: [coachId], references: [id], onDelete: SetNull)
  receiptFiles   ReceiptFile[]
  approvals      ApprovalAction[]
  auditLogs      AuditLog[]
  notifications  Notification[]

  @@index([teamId, status, createdAt])
  @@index([coachId, status])
}

model ReceiptFile {
  id            String            @id @default(cuid())
  requestId     String
  fileName      String
  mimeType      String
  storageUrl    String
  parseStatus   ParseStatus       @default(QUEUED)
  uploadedAt    DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  request       ReimbursementRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  extraction    ReceiptExtraction?

  @@index([requestId, parseStatus])
}

model ReceiptExtraction {
  id            String      @id @default(cuid())
  receiptFileId String      @unique
  documentType  DocumentType @default(OTHER)
  merchant      String?
  receiptDate   DateTime?
  subtotal      Decimal?
  tax           Decimal?
  total         Decimal?
  currency      String?     @default("USD")
  confidence    Float?
  flags         Json?
  rawJson       Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  receiptFile   ReceiptFile @relation(fields: [receiptFileId], references: [id], onDelete: Cascade)
  lineItems     ReceiptLineItem[]
}

model ReceiptLineItem {
  id                  String            @id @default(cuid())
  receiptExtractionId String
  position            Int               @default(0)
  description         String
  quantity            Decimal?
  unitPrice           Decimal?
  lineTotal           Decimal?
  category            String?
  excludedAt          DateTime?
  excludedById        String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  receiptExtraction   ReceiptExtraction @relation(fields: [receiptExtractionId], references: [id], onDelete: Cascade)
  excludedBy          User?             @relation("LineItemExcludedBy", fields: [excludedById], references: [id], onDelete: SetNull)
  comments            LineItemComment[]

  @@index([receiptExtractionId, position])
}

model LineItemComment {
  id         String          @id @default(cuid())
  lineItemId String
  authorId   String
  text       String
  createdAt  DateTime        @default(now())
  lineItem   ReceiptLineItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  author     User            @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([lineItemId, createdAt])
}

model ApprovalAction {
  id         String          @id @default(cuid())
  requestId  String
  actorId    String
  action     DecisionAction
  comment    String?
  createdAt  DateTime        @default(now())
  request    ReimbursementRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actor      User            @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([requestId, createdAt])
}

model AuditLog {
  id         String    @id @default(cuid())
  actorId    String?
  requestId  String?
  eventType  String
  message    String
  metadata   Json?
  createdAt  DateTime  @default(now())
  actor      User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)
  request    ReimbursementRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([requestId, createdAt])
  @@index([eventType, createdAt])
}

model Notification {
  id        String                @id @default(cuid())
  userId    String
  event     String
  message   String
  requestId String?
  read      Boolean               @default(false)
  createdAt DateTime              @default(now())
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  request   ReimbursementRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([userId, read, createdAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
